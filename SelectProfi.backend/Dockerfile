FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

COPY SelectProfi.backend/SelectProfi.backend.csproj SelectProfi.backend/
RUN dotnet restore SelectProfi.backend/SelectProfi.backend.csproj

COPY . .
RUN dotnet publish SelectProfi.backend/SelectProfi.backend.csproj -c Release -o /app/publish --no-restore

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS runtime
WORKDIR /app

ENV ASPNETCORE_URLS=http://+:8080
EXPOSE 8080

COPY --from=build /app/publish .

ENTRYPOINT ["dotnet", "SelectProfi.backend.dll"]
