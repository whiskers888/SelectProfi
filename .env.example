# Optional compose project name to avoid collisions with other local stacks
COMPOSE_PROJECT_NAME=selectprofi

# Published host ports
BACKEND_PORT=5268
FRONTEND_PORT=5173

# Local development database password
POSTGRES_PASSWORD=postgres

# Supabase S3-compatible Storage. Keep access keys only in local env or Render.
S3__ENDPOINT=https://jebnbsehfrkmmvtqlqpa.storage.supabase.co/storage/v1/s3
S3__REGION=eu-west-3
S3__BUCKET=SelectProfiStorage
S3__ACCESSKEYID=
S3__SECRETACCESSKEY=

# Optional remote PostgreSQL connection string. Keep the real value only in .env.
# POSTGRES_CONNECTION_STRING=Host=...;Database=...;Username=...;Password=...;SSL Mode=VerifyFull;Channel Binding=Require
